# Sotto — same-origin deployment.
#
# Serves the built web app and reverse-proxies the API through ONE origin, so the session cookie
# and CSP `connect-src 'self'` stay simple, and no CORS is needed. Caddy provisions HTTPS
# automatically for a real domain.
#
#   1. Build the web app:   cd web && npm ci && npm run build     # → web/dist
#   2. Run the API:         DATABASE_URL=… GITHUB_CLIENT_ID=… GITHUB_CLIENT_SECRET=… \
#                           SOTTO_PUBLIC_URL=https://app.example.com \
#                           SOTTO_WEB_ORIGIN=https://app.example.com  sotto-server
#   3. Run Caddy:           SOTTO_DOMAIN=app.example.com SOTTO_API=127.0.0.1:8080  caddy run
#
# Register the GitHub OAuth app's callback as https://app.example.com/auth/github/callback (same
# origin as the web app), matching SOTTO_PUBLIC_URL.
#
# NOTE: `rate_limit` (below) is the caddy-ratelimit plugin, not a standard directive. The deploy
# image is an xcaddy build that bundles it (deploy/Dockerfile.web); a stock `caddy` binary will
# reject this config.
{
	# rate_limit is a non-standard (plugin) directive, so its place in the handler chain must be
	# declared — run it before the proxy so throttling happens before the request reaches the API.
	order rate_limit before reverse_proxy
}

{$SOTTO_DOMAIN:localhost} {
	encode gzip

	# JSON access logs — ops forensics and the funnel's demand counter: a 402 in these logs is a
	# free-tier limit hit. Written to the caddy_logs volume (deploy/docker-compose.prod.yml) and
	# rotated by Caddy itself. Credential headers (Cookie, Authorization) are redacted by default;
	# see deploy/README.md § Access logs for the reading commands.
	log {
		output file /var/log/caddy/access.log {
			roll_size 50MiB
			roll_keep 10
			roll_keep_for 2160h
		}
		format json
	}

	# Per-client-IP rate limits on the UNAUTHENTICATED endpoints — the only API surface with no
	# credential wall: the OAuth login/callback (which writes a short-lived login-state row), the
	# public share fetch, and the anonymous telemetry ping (a 503 no-op unless this instance sets
	# SOTTO_TELEMETRY_INGEST=1). Caddy is the edge here, so {remote_host} is the real client IP, not a
	# proxied one. Authenticated sync (/account, /projects, /environments/*, /orgs, /machine/*, …) is
	# deliberately NOT limited: it is bearer-gated and includes high-frequency CI polling that a
	# per-IP cap could wrongly throttle when a whole team shares one office/NAT egress IP. The
	# threshold is a generous starting point — raise it, or split into per-endpoint zones, to taste.
	@ratelimited path /auth/github/* /shares /shares/* /telemetry/*
	handle @ratelimited {
		rate_limit {
			zone unauthenticated {
				key {remote_host}
				events 120
				window 1m
			}
		}
		reverse_proxy {$SOTTO_API:127.0.0.1:8080}
	}

	# The rest of the server's API (bearer-authenticated). Together with @ratelimited above this must
	# cover every path the routers in `crates/server/src/lib.rs` serve — keep the two in sync.
	@api path /health /auth/me /auth/logout /account /account/* /projects /projects/* /environments/* /orgs /orgs/* /machine/* /billing/*
	handle @api {
		reverse_proxy {$SOTTO_API:127.0.0.1:8080}
	}

	# Everything else is the SPA, including client-side routes (/, /app, /s/:token, /auth/callback).
	handle {
		root * ./web/dist
		try_files {path} /index.html
		file_server

		# Caching: Vite's content-hashed assets never change under the same name, so they may be
		# cached forever; everything else (index.html, favicons) must revalidate each load via the
		# ETag, so a deploy is visible on the next refresh. Without this, browsers cache the SPA
		# heuristically and keep showing a stale build after upgrades. `?` = set only if unset.
		@hashed path /assets/*
		header @hashed Cache-Control "public, max-age=31536000, immutable"
		header ?Cache-Control "no-cache"
	}

	# Defense-in-depth headers. The CSP is also baked into index.html (build-time) as a fallback for
	# hosts that don't set headers; the header here is authoritative when present.
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self'; img-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}
}
