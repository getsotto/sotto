# Sotto production deployment - copy to deploy/.env and fill in.
#   cp .env.example .env
# .env is gitignored; never commit it.

# The domain the instance is served from (web app + API, one origin). An A/AAAA record must
# point at this host before starting - Caddy provisions the HTTPS certificate automatically.
SOTTO_DOMAIN=app.example.com

# Postgres password for the internal database (not exposed outside the compose network).
# It is interpolated into DATABASE_URL, so keep it URL-safe: letters and digits, e.g.
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# GitHub OAuth app for login. Create one at github.com → Settings → Developer settings →
# OAuth Apps, with the authorization callback URL:
#   https://<SOTTO_DOMAIN>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe billing (optional - leave blank to run without paid tiers; billing endpoints 503).
# From the Stripe dashboard: the secret API key, the signing secret of a webhook endpoint
# pointed at https://<SOTTO_DOMAIN>/billing/webhook (events: checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted), and the Price id of the
# monthly Team subscription.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Telemetry (optional). The server sends one anonymous ping a day - a random instance uuid,
# its version, and os/arch, nothing else (see the README's Telemetry section for the exact
# payload and crates/server/src/telemetry.rs for the code). Set to "off" to disable.
SOTTO_TELEMETRY=

# Off-box backups (strongly recommended): where deploy/backup.sh ships nightly verified
# dumps. The scheme picks the tool - gs://bucket (gsutil), s3://bucket (aws cli), or any
# rclone remote:path (B2, SFTP, a NAS, …). Setup + cron + restore: deploy/README.md § Backups.
SOTTO_BACKUP_BUCKET=
