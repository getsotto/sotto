# Web client + Caddy — multi-stage build (context: the repository root).
#
# The web build is not a plain npm build: `npm run build` first compiles the Rust crypto core to
# WebAssembly with wasm-pack, so the builder needs Node AND a Rust toolchain. The final image is a
# Caddy (built with the caddy-ratelimit plugin — see the Caddyfile) serving the built SPA with the
# repo Caddyfile baked in; Caddy provisions HTTPS automatically for the domain in SOTTO_DOMAIN.

FROM node:22-bookworm AS build

# Rust toolchain (rustup honors the repo's rust-toolchain.toml) + prebuilt wasm-pack. The
# wasm-pack installer needs rustup on PATH, so it runs in a separate layer after ENV PATH.
RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal \
    --default-toolchain stable --target wasm32-unknown-unknown
ENV PATH="/root/.cargo/bin:${PATH}"
RUN curl -fsSL https://rustwasm.github.io/wasm-pack/installer/init.sh | sh

WORKDIR /app
COPY . .
RUN cd web && npm ci && npm run build

# Build a Caddy binary bundling the caddy-ratelimit plugin, which powers the `rate_limit` directive
# in the Caddyfile (stock Caddy has no such directive). The plugin is pinned for reproducible builds;
# the Caddy version tracks the `caddy:2` line, as the runtime stage below already did.
FROM caddy:2-builder AS caddy-build
RUN xcaddy build --with github.com/mholt/caddy-ratelimit@v0.1.0

FROM caddy:2
# Replace stock Caddy with the plugin-enabled build.
COPY --from=caddy-build /usr/bin/caddy /usr/bin/caddy
# The Caddyfile roots the SPA at ./web/dist, relative to Caddy's working directory (/srv).
COPY Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/web/dist /srv/web/dist
